msgctxt "Addon Summary"
msgid "Intellivision controller"
msgstr "Ovladač Intellivision"

msgctxt "Addon Description"
msgid "The Intellivision, a portmanteau of \"intelligent television\", was released by Mattel Electronics in 1979. In 2009, IGN named the Intellivision the 14th greatest console of all time."
msgstr "Intellivision, název vzniklý spojením slov „intelligent television“, byla vydána společností Mattel Electronics v roce 1979. V roce 2009 ji server IGN označil za 14. nejlepší konzoli všech dob."

msgctxt "Addon Disclaimer"
msgid "Image credit: OpenEmu (openemu.org)"
msgstr "Zdroj obrázku: OpenEmu (openemu.org)"

